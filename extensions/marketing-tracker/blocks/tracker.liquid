{% comment %}
  Marketing Solution — Visitor Tracking
  Add your Tracking ID from the app dashboard Overview page.
{% endcomment %}

{% if block.settings.tracking_id != blank %}
<script
  src="{{ block.settings.tracker_url }}/tracker.js"
  data-tracking-id="{{ block.settings.tracking_id }}"
  async
></script>
{% endif %}

{% schema %}
{
  "name": "מעקב Solution",
  "target": "head",
  "settings": [
    {
      "type": "text",
      "id": "tracking_id",
      "label": "מזהה מעקב",
      "info": "מוצג בדף הבית של האפליקציה — Solution"
    },
    {
      "type": "text",
      "id": "tracker_url",
      "label": "כתובת השרת",
      "default": "https://shopify-marketing-solution.onrender.com",
      "info": "השאר ברירת מחדל אלא אם נתנו לך כתובת אחרת"
    }
  ]
}
{% endschema %}
