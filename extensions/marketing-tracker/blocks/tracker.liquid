{% comment %}
  Marketing Solution — Visitor Tracking
  Add your Tracking ID from the app dashboard Overview page.
{% endcomment %}

{% if block.settings.tracking_id != blank %}
<script
  src="{{ block.settings.tracker_url }}/tracker.js"
  data-tracking-id="{{ block.settings.tracking_id }}"
  async
></script>
{% endif %}

{% schema %}
{
  "name": "Solution Tracker",
  "target": "head",
  "settings": [
    {
      "type": "text",
      "id": "tracking_id",
      "label": "Tracking ID",
      "info": "Copy from Solution app → Home page"
    },
    {
      "type": "text",
      "id": "tracker_url",
      "label": "App server URL",
      "default": "https://shopify-marketing-solution.onrender.com",
      "info": "Leave the default unless support gave you a different URL"
    }
  ]
}
{% endschema %}
