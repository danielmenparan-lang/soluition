{
  "name": "shopify-marketing-solution",
  "private": true,
  "scripts": {
    "build": "react-router build",
    "dev": "shopify app dev",
    "config:link": "shopify app config link",
    "generate": "shopify app generate",
    "deploy": "shopify app deploy --allow-updates",
    "deploy:shopify": "shopify app deploy --allow-updates --message \"Production URL sync\"",
    "config:use": "shopify app config use",
    "env": "shopify app env",
    "start": "react-router-serve ./build/server/index.js",
    "start:render": "node ./node_modules/@react-router/serve/dist/cli.js ./build/server/index.js",
    "start:production": "node scripts/render-start.mjs",
    "docker-start": "node scripts/start-production.mjs",
    "setup": "prisma generate && prisma migrate deploy",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "shopify": "shopify",
    "prisma": "prisma",
    "typecheck": "react-router typegen && tsc --noEmit",
    "db:seed": "tsx scripts/seed-demo-data.ts",
    "ai:test": "tsx scripts/test-ai-pipeline.ts",
    "db:test": "node scripts/test-database-url.mjs",
    "db:migrate": "prisma migrate deploy"
  },
  "type": "module",
  "engines": {
    "node": ">=20.19 <22 || >=22.12"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@prisma/client": "^6.16.3",
    "@react-router/dev": "^7.12.0",
    "@react-router/fs-routes": "^7.12.0",
    "@react-router/node": "^7.12.0",
    "@react-router/serve": "^7.12.0",
    "@shopify/app-bridge-react": "^4.2.4",
    "@shopify/shopify-app-react-router": "^1.1.0",
    "@shopify/shopify-app-session-storage-prisma": "^9.0.0",
    "@supabase/supabase-js": "^2.49.1",
    "isbot": "^5.1.31",
    "prisma": "^6.16.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.12.0",
    "vite-tsconfig-paths": "^6.0.4",
    "ws": "^8.21.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@shopify/polaris-types": "1.0.1",
    "@types/node": "^25.5.2",
    "@types/react": "^18.3.25",
    "@types/react-dom": "^18.3.7",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "workspaces": {
    "packages": [
      "extensions/*"
    ]
  }
}
