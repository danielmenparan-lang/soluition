# Shopify App (auto-filled by `shopify app dev`)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://shopify-marketing-solution.onrender.com
SCOPES=

# Supabase (REST API for analytics)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Claude AI
ANTHROPIC_API_KEY=sk-ant-...
# Optional — defaults to claude-sonnet-4-6 (claude-sonnet-4-20250514 was retired June 2026)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Merchant support email (shown in app footer + privacy page)
SUPPORT_EMAIL=vonx.support@gmail.com

# Shopify sessions (Prisma) — MUST be Postgres in production (Render)
# Dev only:  file:./dev.sqlite  (requires prisma schema provider sqlite — not used on Render)
# Production (Render): Session pooler — NOT db.*.supabase.co (IPv6, fails on Render)
# Supabase → Connect → Session mode → URI → copy region from there
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?connect_timeout=30
