# Shopify App (auto-filled by `shopify app dev`)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://shopify-marketing-solution.onrender.com
SCOPES=read_products,read_orders,read_customers,read_analytics,write_script_tags,read_content

# Supabase (REST API for analytics)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Claude AI
ANTHROPIC_API_KEY=sk-ant-...

# Shopify sessions (Prisma) — MUST be Postgres in production (Render)
# Dev only:  file:./dev.sqlite  (requires prisma schema provider sqlite — not used on Render)
# Production: Supabase → Settings → Database → URI (port 5432, direct connection)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
