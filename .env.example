# Shopify App (auto-filled by `shopify app dev`)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=
SCOPES=read_products,read_orders,read_customers,read_analytics,write_script_tags,read_content

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Claude AI
ANTHROPIC_API_KEY=sk-ant-...

# Database — Shopify sessions
# Dev (SQLite):  file:./dev.sqlite
# Production:    Supabase Postgres connection string from Dashboard → Settings → Database
DATABASE_URL=file:./dev.sqlite
